# ─────────────────────────────────────────────────────────────
# SkillMap backend — environment variables
# Copy to `.env` for local dev; set the same keys in the Render
# dashboard for production. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# ── Django core ──
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True                       # True for local dev only. MUST be False in production.
ALLOWED_HOSTS=localhost,127.0.0.1,api.doithere.in,skillmap-backend-498t.onrender.com

# ── Database (Supabase Postgres) ──
# WARNING: this points at the SHARED production DB — running `migrate`
# locally will change production. Use a separate DB for real local dev.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# ── CORS — frontend origins allowed to call the API ──
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://doithere.in,https://www.doithere.in

# ── Cloudinary — avatars + post photos ──
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Email ──
RESEND_API_KEY=your-resend-key          # OTP verification & login codes
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
EMAIL_PORT=587
EMAIL_USE_TLS=True
